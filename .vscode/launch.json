{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Go Server",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/sandbox/main.go",
            "env": {
                "PORT": "8080",
                "ENV": "development",
                "JWT_SECRET": "secret@123"
            },
            "args": [],
            "showLog": true
        },
        {
            "name": "Launch Go Package",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}",
            "env": {
                "JWT_SECRET": "secret@123"
            },
            "args": []
        },
        {
            "name": "Attach to Running Process",
            "type": "go",
            "request": "attach",
            "mode": "local",
            "processId": "${command:pickProcess}"
        },
        {
            "name": "Attach to Remote (Delve)",
            "type": "go",
            "request": "attach",
            "mode": "remote",
            "remotePath": "${workspaceFolder}",
            "port": 2345,
            "host": "127.0.0.1"
        }
    ]
}